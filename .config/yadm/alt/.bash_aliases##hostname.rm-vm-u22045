
alias nv='nvim'

alias bear-make='bear -- make -j'

alias lg='lazygit'

# for go
export GO_SOURCE_URL="git@github.com:golang/go.git"
export GO_BINARY_BASE_URL=https://golang.google.cn/dl/

# for pyenv
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init - bash)"
eval "$(pyenv virtualenv-init -)"

# for repo
export REPO_URL=/mnt/xia-disk/soft/repo/repo-git
export REPO_REV=main

function repo-push() {
    local remote="$1"
    local branch="$2"

    if [ -z "$remote" ] || [ -z "$branch" ]; then
        echo "Usage: repo-push <remote> <branch>"
        echo "Example: repo-push xia dev"
        return 1
    fi

    repo forall -c '
        if ! git remote get-url "'"$remote"'" >/dev/null 2>&1; then
            exit 0
        fi

        echo "------------------------------------------------------"
        echo "🔷 仓库: $REPO_PROJECT, 分支: '$remote/$branch'"

        tmpfile="/tmp/gitout.$$.$REPO_PROJECT"
        git push '$remote' '$branch' > "$tmpfile" 2>&1
        ret=$?
        cat "$tmpfile" && rm -f "$tmpfile"
        if [ $ret -ne 0 ]; then
            echo "❌❌❌推送失败❌❌❌"
        fi
    '
}

